function addCart(){
  var btn=document.getElementById('cartBtn');
  var origHtml=btn?btn.innerHTML:'';
  if(btn){btn.textContent='Adding...';btn.disabled=true}
  if(window.fbq)fbq('track','AddToCart',{content_name:'AirClip Mini Fan',content_type:'product',value:{{ product.price | divided_by: 100.0 }},currency:'USD'});
  fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:variantId,quantity:qty})})
  .then(function(r){return r.json()})
  .then(function(){
    if(btn){btn.innerHTML=origHtml;btn.disabled=false}
    openDrawer();
  })
  .catch(function(){
    if(btn){btn.innerHTML=origHtml;btn.disabled=false}
    openDrawer();
  });
}
function buyNow(){
  var btn=document.querySelector('.btn-now');
  if(btn){btn.textContent='Going to checkout...';btn.disabled=true}
  if(window.fbq)fbq('track','InitiateCheckout',{content_name:'AirClip Mini Fan',content_type:'product',value:{{ product.price | divided_by: 100.0 }},currency:'USD'});
  fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:variantId,quantity:qty})})
  .then(function(){window.location.href='/checkout'})
  .catch(function(){window.location.href='/checkout'});
}
