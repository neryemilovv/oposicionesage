// SLIDER
var sl=0,total=6;
(function initDots(){var d=document.getElementById('slDots');for(var i=0;i<total;i++){var dot=document.createElement('div');dot.className='dot'+(i===0?' on':'');dot.onclick=(function(i){return function(){goSlide(i)}})(i);d.appendChild(dot)}})();
function goSlide(n){sl=n;document.getElementById('slTrack').style.transform='translateX(-'+sl*100+'%)';document.querySelectorAll('.dot').forEach(function(d,i){d.className='dot'+(i===sl?' on':'')})}
function slide(d){goSlide((sl+d+total)%total)}
setInterval(function(){slide(1)},3500);

// BUNDLE PICK
var qty=1;
function pick(c,p,q){document.querySelectorAll('.b-card').forEach(function(x){x.classList.remove('sel')});c.classList.add('sel');qty=q;document.getElementById('showPrice').textContent=p;document.getElementById('cartP').textContent=p;document.getElementById('mP').textContent=p}

// COLOR
var variantId=61916644180298;
function col(s,n,vid,img){document.querySelectorAll('.c-swatch').forEach(function(x){x.classList.remove('sel')});s.classList.add('sel');document.getElementById('colorName').textContent=n;variantId=vid;if(img){var h=document.getElementById('heroImg');if(h)h.src=img;goSlide(0);}}

// CART DRAWER
function openDrawer(){
  document.getElementById('cdOverlay').classList.add('open');
  document.getElementById('cdDrawer').classList.add('open');
  document.body.style.overflow='hidden';
  fetchCart();
}
function closeDrawer(){
  document.getElementById('cdOverlay').classList.remove('open');
  document.getElementById('cdDrawer').classList.remove('open');
  document.body.style.overflow='';
}
function fetchCart(){
  fetch('/cart.js').then(function(r){return r.json()}).then(function(cart){
    var body=document.getElementById('cdBody');
    var foot=document.getElementById('cdFoot');
    var totalEl=document.getElementById('cdTotal');
    var shipNote=document.getElementById('cdShipNote');
    var navCount=document.getElementById('navCartCount');
    var totalQty=cart.items.reduce(function(s,i){return s+i.quantity},0);
    if(navCount){if(totalQty>0){navCount.textContent=totalQty;navCount.style.display='flex'}else{navCount.style.display='none'}}
    if(!cart.items.length){
      body.innerHTML='<div class="cd-empty">🛒 Your cart is empty</div>';
      foot.style.display='none';return;
    }
    foot.style.display='flex';
    var total=cart.total_price/100;
    totalEl.textContent='$'+total.toFixed(2);
    shipNote.style.display='block';
    body.innerHTML=cart.items.map(function(item){
      var img=item.image||'';
      var vt=item.variant_title&&item.variant_title!=='Default Title'?'<div class="cd-item-var">'+item.variant_title+'</div>':'';
      return '<div class="cd-item">'
        +'<img class="cd-item-img" src="'+img+'" alt="'+item.product_title+'">'
        +'<div class="cd-item-info">'
        +'<div class="cd-item-name">'+item.product_title+'</div>'
        +vt
        +'<div class="cd-item-bottom">'
        +'<div class="cd-qty-ctrl">'
        +'<button onclick="chgQty(\''+item.key+'\','+(item.quantity-1)+')">−</button>'
        +'<span>'+item.quantity+'</span>'
        +'<button onclick="chgQty(\''+item.key+'\','+(item.quantity+1)+')">+</button>'
        +'</div>'
        +'<span class="cd-item-price">$'+(item.final_line_price/100).toFixed(2)+'</span>'
        +'</div>'
        +'<button class="cd-item-remove" onclick="chgQty(\''+item.key+'\',0)">Remove</button>'
        +'</div></div>';
    }).join('');
  }).catch(function(){document.getElementById('cdBody').innerHTML='<div class="cd-empty">Error loading cart. Please refresh.</div>';});
}
function chgQty(key,qty){
  fetch('/cart/change.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:key,quantity:qty})})
  .then(function(r){return r.json()}).then(function(){fetchCart()});
}
function updateCartCount(){
  fetch('/cart.js').then(function(r){return r.json()}).then(function(cart){
    var n=document.getElementById('navCartCount');
    if(!n)return;
    var q=cart.items.reduce(function(s,i){return s+i.quantity},0);
    if(q>0){n.textContent=q;n.style.display='flex'}else{n.style.display='none'}
  });
}
updateCartCount();

