// VIDEO PLAY
// COUNTDOWN
(function(){var end=Date.now()+(4*3600+59*60+59)*1000;var el=document.getElementById('cdClock');function tick(){var d=Math.max(0,end-Date.now());if(d<=0){end=Date.now()+5*3600*1000;d=5*3600*1000}var h=Math.floor(d/3600000),m=Math.floor(d%3600000/60000),s=Math.floor(d%60000/1000);if(el)el.textContent=(h<10?'0':'')+h+':'+(m<10?'0':'')+m+':'+(s<10?'0':'')+s;}tick();setInterval(tick,1000);})();
(function(){var el=document.getElementById('liveN');setInterval(function(){if(el){el.textContent=26+Math.floor(Math.random()*16);}},4000);})();
(function(){var el=document.getElementById('stockN');var n=47;setInterval(function(){if(el&&n>9&&Math.random()>0.6){n--;el.textContent=n;}},22000);})();

function faq(b){var it=b.parentElement;it.classList.toggle('open')}
function qa(b){var it=b.parentElement;it.classList.toggle('open')}

function initVideos(){
  var vids=document.querySelectorAll('.vid-phone');
  vids.forEach(function(phone,i){
    var vid=phone.querySelector('video');
    var ov=phone.querySelector('.vid-overlay');
    ov.addEventListener('click',function(){
      vid.play();
      ov.classList.add('hide');
    });
    vid.addEventListener('click',function(){
      if(vid.paused){vid.play();ov.classList.add('hide')}
      else{vid.pause();ov.classList.remove('hide')}
    });
  });
  // autoplay on scroll
  var obs=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      var v=e.target.querySelector('video');
      var o=e.target.querySelector('.vid-overlay');
      if(e.isIntersecting){if(v)v.play();if(o)o.classList.add('hide')}
      else{if(v)v.pause();if(o)o.classList.remove('hide')}
    });
  },{threshold:0.6});
  vids.forEach(function(p){obs.observe(p)});
}
initVideos();
