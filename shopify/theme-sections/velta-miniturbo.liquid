// COUNTDOWN TIMER
(function(){
  var end=Date.now()+ (4*3600+59*60+59)*1000;
  var el=document.getElementById('cdClock');
  function tick(){
    var d=Math.max(0,end-Date.now());
    if(d<=0){end=Date.now()+5*3600*1000;d=5*3600*1000}
    var h=Math.floor(d/3600000),m=Math.floor(d%3600000/60000),s=Math.floor(d%60000/1000);
    if(el)el.textContent=(h<10?'0':'')+h+':'+(m<10?'0':'')+m+':'+(s<10?'0':'')+s;
  }
  tick();setInterval(tick,1000);
})();
// LIVE VIEWERS (fluctua)
(function(){
