<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
.shopify-section-group-header-group,.section-header,#shopify-section-announcement-bar,.announcement-bar,.utility-bar,header.header,.header-wrapper,#shopify-section-header{display:none!important}
body{padding-top:0!important}
*{margin:0;padding:0;box-sizing:border-box}
:root{--teal:#1a6b5e;--teal-d:#0d4a41;--teal-l:#e8f5f2;--gold:#c9922a;--dark:#0f172a;--gray:#64748b;--light:#f8fafc;--border:#e2e8f0;--red:#ef4444;--green:#22c55e;--white:#fff}
body{font-family:'Inter',sans-serif;color:var(--dark);background:#fff;overflow-x:hidden}
.ann{background:#0a0a0a;color:rgba(255,255,255,.9);text-align:center;padding:8px 16px;font-size:12px;font-weight:500;border-bottom:1px solid #1a1a1a}
.ann strong{color:#ffd700}
header{position:sticky;top:0;z-index:999;background:#0a0a0a;padding:0 32px;height:56px;display:flex;align-items:center;justify-content:space-between}
.logo{font-size:20px;font-weight:700;color:#fff;letter-spacing:0;text-decoration:none}.logo span{color:#c8a96e}
nav a{font-size:14px;color:rgba(255,255,255,.85);text-decoration:none;font-weight:500;margin-left:24px;transition:color .2s}
nav a:hover{color:#c8a96e}
.h-right{display:flex;align-items:center;gap:16px;font-size:13px;color:rgba(255,255,255,.7)}
@media(max-width:768px){nav,.h-right{display:none}}
.mob-cart-icon{display:none;background:none;border:none;cursor:pointer;font-size:22px;padding:4px 8px;position:relative;margin-left:auto}
@media(max-width:768px){.mob-cart-icon{display:flex;align-items:center}}
.product-wrap{max-width:1200px;margin:0 auto;padding:24px 24px 60px;display:grid;grid-template-columns:1fr 460px;gap:56px;align-items:start}
@media(max-width:960px){.product-wrap{grid-template-columns:1fr;gap:32px}}
.gallery{position:sticky;top:76px}
@media(max-width:960px){.gallery{position:static}}
.slider{border-radius:20px;overflow:hidden;background:var(--light);aspect-ratio:1;position:relative}
.slider-track{display:flex;transition:transform .4s cubic-bezier(.4,0,.2,1)}
.slide{min-width:100%;aspect-ratio:1}
.slide img{width:100%;height:100%;object-fit:cover}
.slider-dots{display:flex;justify-content:center;gap:8px;margin-top:12px}
.dot{width:8px;height:8px;border-radius:50%;background:var(--border);cursor:pointer;transition:all .2s}
.dot.on{background:var(--teal);width:24px;border-radius:4px}
.slider-prev,.slider-next{position:absolute;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.9);border:none;width:40px;height:40px;border-radius:50%;cursor:pointer;font-size:18px;color:var(--dark);box-shadow:0 2px 12px rgba(0,0,0,.12);transition:all .2s;z-index:2}
.slider-prev{left:12px}.slider-next{right:12px}
.slider-prev:hover,.slider-next:hover{background:#fff;box-shadow:0 4px 20px rgba(0,0,0,.2)}
.p-info{display:flex;flex-direction:column;gap:20px}
.p-badge{display:inline-flex;align-items:center;gap:6px;background:var(--teal-l);color:var(--teal);font-size:11px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;padding:5px 12px;border-radius:20px;width:fit-content}
.p-title{font-size:30px;font-weight:900;line-height:1.15;color:var(--dark);margin-top:6px}
.p-sub{font-size:14px;color:var(--gray);margin-top:6px;line-height:1.6}
.stars-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.stars{color:#f59e0b;font-size:17px}
.review-count{font-size:13px;color:var(--gray);text-decoration:underline;cursor:pointer}
.sold-badge{background:#fef3c7;color:#92400e;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px}
.price-row{display:flex;align-items:baseline;gap:10px;padding:16px 0;border-top:1px solid var(--border)}
.price-now{font-size:38px;font-weight:900;color:var(--teal)}
.price-was{font-size:18px;color:var(--gray);text-decoration:line-through}
.price-off{font-size:14px;color:var(--red);font-weight:700;background:#fef2f2;padding:3px 8px;border-radius:6px}
.stock-note{font-size:12px;color:var(--red);font-weight:600;margin-top:4px;display:flex;align-items:center;gap:6px}
.bundle-title{font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.8px;color:var(--dark);margin-bottom:10px}
.bundles{display:flex;flex-direction:column;gap:10px}
.b-card{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;border:2px solid var(--border);border-radius:14px;cursor:pointer;transition:all .2s;position:relative}
.b-card.sel{border-color:var(--teal);background:var(--teal-l)}
.b-card:hover{border-color:var(--teal)}
.b-left{display:flex;align-items:center;gap:12px}
.b-radio{width:20px;height:20px;border-radius:50%;border:2px solid #cbd5e1;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .2s}
.b-card.sel .b-radio{border-color:var(--teal);background:var(--teal)}
.b-card.sel .b-radio::after{content:'';width:8px;height:8px;border-radius:50%;background:#fff}
.b-qty{font-weight:800;font-size:15px}.b-desc{font-size:12px;color:var(--gray);margin-top:2px}
.b-right{text-align:right}.b-price{font-weight:900;font-size:17px}.b-per{font-size:11px;color:var(--gray)}
.b-tag{position:absolute;top:-10px;right:14px;font-size:10px;font-weight:800;letter-spacing:.5px;padding:2px 9px;border-radius:20px;color:#fff}
.opt-title{font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.8px;margin-bottom:10px}
.opt-title span{color:var(--teal);font-weight:900}
.colors{display:flex;gap:10px}
.c-swatch{display:flex;flex-direction:column;align-items:center;gap:6px;cursor:pointer}
.c-circle{width:42px;height:42px;border-radius:50%;border:3px solid transparent;box-shadow:0 2px 8px rgba(0,0,0,.15);transition:border-color .2s}
.c-swatch.sel .c-circle,.c-swatch:hover .c-circle{border-color:var(--teal)}
.c-label{font-size:11px;color:var(--gray);font-weight:500}
.btns{display:flex;flex-direction:column;gap:10px}
.btn-cart{width:100%;padding:18px;background:var(--teal);color:#fff;font-size:17px;font-weight:800;border:none;border-radius:14px;cursor:pointer;transition:all .2s;letter-spacing:.2px}
.btn-cart:hover{background:var(--teal-d);transform:translateY(-1px);box-shadow:0 8px 24px rgba(26,107,94,.3)}
.btn-cart:active{transform:translateY(0)}
.btn-now{width:100%;padding:16px;background:#000;color:#fff;font-size:16px;font-weight:700;border:none;border-radius:14px;cursor:pointer;transition:all .2s}
.btn-now:hover{opacity:.85}
.bullets{border-top:1px solid var(--border);padding-top:20px;display:flex;flex-direction:column;gap:12px}
.bull{display:flex;align-items:flex-start;gap:12px}
.bull-icon{width:36px;height:36px;border-radius:10px;background:var(--teal-l);color:var(--teal);display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
.bull-t{font-weight:700;font-size:14px}.bull-d{font-size:12px;color:var(--gray);margin-top:2px}
.trust{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;border-top:1px solid var(--border);padding-top:20px}
.trust-item{display:flex;flex-direction:column;align-items:center;text-align:center;gap:4px}
.trust-item .icon{font-size:22px}.trust-item .t{font-size:11px;font-weight:700}.trust-item .s{font-size:10px;color:var(--gray)}
.pay-icons{text-align:center;font-size:12px;color:var(--gray);padding-top:4px}
.proof-bar{background:var(--dark);padding:16px 24px;overflow:hidden}
.proof-track{display:flex;gap:48px;animation:scroll 20s linear infinite;width:max-content}
.proof-track span{color:rgba(255,255,255,.7);font-size:13px;font-weight:500;white-space:nowrap}
.proof-track strong{color:#fff}
@keyframes scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.features{background:#fff;padding:80px 24px}
.feat-inner{max-width:1100px;margin:0 auto;display:flex;flex-direction:column;gap:80px}
.feat-row{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
.feat-row.rev{direction:rtl}.feat-row.rev>*{direction:ltr}
@media(max-width:768px){.feat-row,.feat-row.rev{grid-template-columns:1fr;direction:ltr}.feat-row.rev>*{direction:ltr}}
.feat-img{border-radius:20px;overflow:hidden;box-shadow:0 20px 50px rgba(0,0,0,.12)}
.feat-img img{width:100%;display:block}
.feat-content{display:flex;flex-direction:column;gap:18px}
.feat-tag{display:inline-block;background:var(--teal-l);color:var(--teal);font-size:11px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;padding:4px 12px;border-radius:20px;width:fit-content}
.feat-h{font-size:34px;font-weight:900;line-height:1.15}
.feat-h em{color:var(--teal);font-style:normal}
.feat-p{font-size:15px;color:var(--gray);line-height:1.8}
.feat-bullets{display:flex;flex-direction:column;gap:10px}
.feat-bull{display:flex;align-items:center;gap:10px;font-size:14px;font-weight:600}
.feat-bull::before{content:'✓';color:var(--green);font-weight:900;font-size:16px;flex-shrink:0}
.sec-hd{text-align:center;max-width:640px;margin:0 auto 50px}
.sec-hd h2{font-size:38px;font-weight:900;line-height:1.15}
.sec-hd h2 em{color:var(--teal);font-style:normal}
.sec-hd p{font-size:16px;color:var(--gray);margin-top:10px;line-height:1.7}
.vidtest-sec{padding:80px 24px;background:var(--dark)}
.vidtest-inner{max-width:1100px;margin:0 auto}
.vidtest-inner .sec-hd h2{color:#fff}
.vidtest-inner .sec-hd p{color:rgba(255,255,255,.6)}
.vid-row{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
@media(max-width:768px){.vid-row{grid-template-columns:1fr}}
.vid-phone{border-radius:24px;overflow:hidden;background:#111;aspect-ratio:9/16;position:relative;cursor:pointer;box-shadow:0 20px 60px rgba(0,0,0,.5)}
.vid-phone video{width:100%;height:100%;object-fit:cover;display:block}
.vid-overlay{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.3);transition:opacity .3s}
.vid-overlay.hide{opacity:0;pointer-events:none}
.play-btn{width:72px;height:72px;border-radius:50%;background:rgba(255,255,255,.95);display:flex;align-items:center;justify-content:center;font-size:28px;color:var(--teal);transition:transform .2s}
.play-btn:hover{transform:scale(1.1)}
.vid-info{padding:16px;background:rgba(255,255,255,.06);border-top:1px solid rgba(255,255,255,.1)}
.vid-stars{color:#ffd700;font-size:13px;margin-bottom:4px}
.vid-quote{color:rgba(255,255,255,.85);font-size:13px;font-style:italic;line-height:1.6;margin-bottom:8px}
.vid-author{font-size:12px;color:rgba(255,255,255,.5);font-weight:600}
.vid-views{display:inline-flex;align-items:center;gap:4px;background:rgba(255,255,255,.08);color:rgba(255,255,255,.5);font-size:11px;padding:2px 8px;border-radius:20px;margin-top:4px}
.test-sec{padding:80px 24px;background:var(--teal)}
.test-inner{max-width:1100px;margin:0 auto}
.test-inner .sec-hd h2{color:#fff}
.test-inner .sec-hd p{color:rgba(255,255,255,.7)}
.test-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
@media(max-width:768px){.test-grid{grid-template-columns:1fr}}
.test-card{background:rgba(255,255,255,.1);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.2);border-radius:20px;padding:28px 24px}
.t-stars{color:#ffd700;font-size:16px;margin-bottom:12px}
.t-text{font-size:15px;color:rgba(255,255,255,.9);line-height:1.75;margin-bottom:20px;font-style:italic}
.t-author{display:flex;align-items:center;gap:12px}
.t-avatar{width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,.25);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:900;color:#fff}
.t-name{font-weight:700;color:#fff;font-size:14px}
.t-meta{font-size:11px;color:rgba(255,255,255,.6)}
.verified{color:#4ade80;font-size:10px;font-weight:700}
.rb-wrap{max-width:480px;margin:48px auto 0}
.rb-number{text-align:center;color:#fff;font-size:52px;font-weight:900}
.rb-stars-big{text-align:center;color:#ffd700;font-size:26px;margin-bottom:20px}
.rb-row{display:flex;align-items:center;gap:10px;color:rgba(255,255,255,.8);font-size:13px;margin-bottom:8px}
.rb-bar{flex:1;height:8px;background:rgba(255,255,255,.2);border-radius:4px;overflow:hidden}
.rb-fill{height:100%;background:#ffd700;border-radius:4px}
.rb-label{width:40px;font-size:11px}
.rb-note{text-align:center;color:rgba(255,255,255,.5);font-size:12px;margin-top:12px}
.specs-sec{padding:80px 24px;background:#fff}
.specs-inner{max-width:700px;margin:0 auto}
.spec-table{width:100%;border-collapse:collapse;border-radius:16px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,.08)}
.spec-table thead{background:var(--teal);color:#fff}
.spec-table th{padding:16px 20px;font-size:13px;font-weight:700;text-align:left}
.spec-table td{padding:13px 20px;font-size:13px;border-bottom:1px solid var(--border)}
.spec-table tr:nth-child(even) td{background:var(--light)}
.spec-table tr:last-child td{border:none}
.sn{font-weight:700}.sv{color:var(--gray)}
.faq-sec{padding:80px 24px;background:var(--light)}
.faq-inner{max-width:700px;margin:0 auto}
.faq-list{display:flex;flex-direction:column;gap:12px}
.faq-item{border:1px solid var(--border);border-radius:14px;overflow:hidden;background:#fff}
.faq-q{width:100%;padding:18px 20px;background:#fff;border:none;cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-size:15px;font-weight:600;text-align:left;transition:background .2s}
.faq-q:hover{background:var(--light)}
.faq-arr{font-size:22px;color:var(--teal);transition:transform .3s;line-height:1}
.faq-item.open .faq-arr{transform:rotate(45deg)}
.faq-a{display:none;padding:0 20px 18px;font-size:14px;color:var(--gray);line-height:1.75}
.faq-item.open .faq-a{display:block}
.also-sec{padding:80px 24px;background:#fff}
.also-inner{max-width:900px;margin:0 auto}
.also-card{background:var(--light);border-radius:20px;overflow:hidden;box-shadow:0 8px 30px rgba(0,0,0,.08);display:grid;grid-template-columns:1fr 1fr;align-items:center}
@media(max-width:600px){.also-card{grid-template-columns:1fr}}
.also-img{background:#e8f5f2;min-height:300px;display:flex;align-items:center;justify-content:center;font-size:80px}
.also-info{padding:40px 36px}
.also-tag{font-size:11px;font-weight:700;color:var(--teal);text-transform:uppercase;letter-spacing:.8px;margin-bottom:10px}
.also-title{font-size:24px;font-weight:900;margin-bottom:12px;line-height:1.2}
.also-desc{font-size:14px;color:var(--gray);line-height:1.7;margin-bottom:24px}
.also-price{font-size:28px;font-weight:900;color:var(--teal);margin-bottom:20px}
.btn-also{display:inline-block;padding:14px 28px;background:var(--teal);color:#fff;font-size:15px;font-weight:700;border-radius:12px;text-decoration:none;transition:all .2s}
.btn-also:hover{background:var(--teal-d);transform:translateY(-1px)}
.cta-sec{background:linear-gradient(135deg,var(--teal-d),var(--teal));padding:80px 24px;text-align:center}
.cta-sec h2{font-size:42px;font-weight:900;color:#fff;margin-bottom:12px}
.cta-sec p{font-size:18px;color:rgba(255,255,255,.8);margin-bottom:36px}
.cta-btn{display:inline-block;padding:20px 48px;background:#fff;color:var(--teal);font-size:18px;font-weight:900;border:none;border-radius:14px;cursor:pointer;text-decoration:none;transition:all .2s}
.cta-btn:hover{transform:translateY(-2px);box-shadow:0 12px 40px rgba(0,0,0,.2)}
.cta-trust{display:flex;justify-content:center;gap:36px;margin-top:24px;flex-wrap:wrap}
.cta-trust span{color:rgba(255,255,255,.7);font-size:13px;display:flex;align-items:center;gap:6px}
footer{background:var(--dark);color:rgba(255,255,255,.4);text-align:center;padding:28px 24px;font-size:13px}
footer strong{color:rgba(255,255,255,.9)}
footer a{color:rgba(255,255,255,.3);text-decoration:none;margin:0 8px}
.sticky-bar{display:none;position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:2px solid var(--border);box-shadow:0 -4px 20px rgba(0,0,0,.15);padding:14px 20px;padding-bottom:max(18px,env(safe-area-inset-bottom,18px));z-index:500;transition:transform .3s}
.sticky-bar.hidden{transform:translateY(100%)}
@media(max-width:960px){.sticky-bar{display:block}}
.sticky-row{display:flex;align-items:center;gap:14px}
.sticky-price{font-size:20px;font-weight:900;color:var(--teal);flex-shrink:0}
.sticky-bar .btn-cart{flex:1;padding:14px;font-size:15px}
.toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--teal);color:#fff;padding:14px 24px;border-radius:12px;font-size:15px;font-weight:600;opacity:0;transition:all .3s;z-index:1000;white-space:nowrap;box-shadow:0 8px 30px rgba(0,0,0,.2)}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
.cd-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9998;opacity:0;pointer-events:none;transition:opacity .3s}
.cd-overlay.open{opacity:1;pointer-events:all}
.cd-drawer{position:fixed;right:0;top:0;bottom:0;width:420px;max-width:96vw;background:#fff;z-index:9999;transform:translateX(100%);transition:transform .35s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;box-shadow:-4px 0 40px rgba(0,0,0,.18)}
.cd-drawer.open{transform:translateX(0)}
.cd-head{display:flex;align-items:center;justify-content:space-between;padding:20px 24px;border-bottom:1px solid var(--border)}
.cd-head h3{font-size:18px;font-weight:800;color:var(--dark)}
.cd-head-close{background:none;border:none;font-size:22px;cursor:pointer;color:var(--gray);line-height:1;padding:4px}
.cd-body{flex:1;overflow-y:auto;padding:0 24px}
.cd-empty{text-align:center;padding:60px 0;color:var(--gray);font-size:15px}
.cd-item{display:flex;gap:14px;padding:18px 0;border-bottom:1px solid var(--border)}
.cd-item-img{width:80px;height:80px;border-radius:10px;object-fit:cover;background:var(--light);flex-shrink:0}
.cd-item-info{flex:1;display:flex;flex-direction:column;gap:6px}
.cd-item-name{font-weight:700;font-size:14px;color:var(--dark);line-height:1.3}
.cd-item-var{font-size:12px;color:var(--gray)}
.cd-item-bottom{display:flex;align-items:center;justify-content:space-between;margin-top:4px}
.cd-qty-ctrl{display:flex;align-items:center;border:1.5px solid var(--border);border-radius:8px;overflow:hidden}
.cd-qty-ctrl button{width:32px;height:32px;background:none;border:none;cursor:pointer;font-size:17px;font-weight:700;color:var(--dark);transition:background .15s}
.cd-qty-ctrl button:hover{background:var(--light)}
.cd-qty-ctrl span{min-width:32px;text-align:center;font-weight:700;font-size:14px}
.cd-item-remove{background:none;border:none;font-size:12px;color:var(--gray);cursor:pointer;text-decoration:underline;padding:0;margin-top:2px;align-self:flex-start}
.cd-item-price{font-weight:900;font-size:16px;color:var(--dark);white-space:nowrap}
.cd-foot{padding:20px 24px;border-top:1px solid var(--border);display:flex;flex-direction:column;gap:12px;background:#fff}
.cd-total-row{display:flex;justify-content:space-between;align-items:center}
.cd-total-label{font-size:15px;font-weight:600;color:var(--gray)}
.cd-total-val{font-size:22px;font-weight:900;color:var(--dark)}
.cd-shipping-note{font-size:12px;color:var(--green);text-align:center;font-weight:600}
.cd-checkout-btn{display:block;text-align:center;background:var(--teal);color:#fff;padding:17px;border-radius:13px;font-size:16px;font-weight:800;text-decoration:none;transition:background .2s;border:none;cursor:pointer;width:100%}
.cd-checkout-btn:hover{background:var(--teal-d);color:#fff}
.cd-continue-btn{background:none;border:1.5px solid var(--border);color:var(--gray);padding:12px;border-radius:10px;font-size:14px;cursor:pointer;font-weight:500;width:100%;transition:all .2s}
.cd-continue-btn:hover{border-color:var(--teal);color:var(--teal)}
.cd-pay-badges{text-align:center;font-size:12px;color:var(--gray)}
.gift-banner{background:linear-gradient(135deg,#00695c,#004d40);border-radius:16px;padding:16px 18px;margin:8px 0 4px;display:flex;align-items:center;gap:14px}
/* CONVERSION BOOST */
.cd-timer{background:linear-gradient(135deg,#e53935,#b71c1c);color:#fff;border-radius:14px;padding:14px 18px;text-align:center;margin:4px 0}
.cd-timer .lbl{font-size:12px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;opacity:.95}
.cd-timer .clock{font-size:26px;font-weight:900;letter-spacing:1px;margin-top:4px;font-variant-numeric:tabular-nums}
.live-view{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--red);font-weight:700;margin-top:4px}
.live-dot{width:9px;height:9px;border-radius:50%;background:var(--red);animation:pulse 1.4s infinite}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(239,68,68,.6)}70%{box-shadow:0 0 0 8px rgba(239,68,68,0)}100%{box-shadow:0 0 0 0 rgba(239,68,68,0)}}
.guarantee-box{background:linear-gradient(135deg,#1a6b5e,#0d4a41);border-radius:18px;padding:26px 22px;text-align:center;color:#fff;margin:8px 0}
.guarantee-box .g-ico{font-size:40px}
.guarantee-box .g-t{font-size:20px;font-weight:900;margin-top:6px}
.guarantee-box .g-d{font-size:13px;opacity:.85;margin-top:6px;line-height:1.5}
.buy-notif{position:fixed;bottom:20px;left:20px;background:#fff;border-radius:14px;box-shadow:0 8px 40px rgba(0,0,0,.2);padding:12px 16px;display:flex;align-items:center;gap:12px;z-index:9990;max-width:300px;transform:translateX(-380px);transition:transform .5s cubic-bezier(.4,0,.2,1)}
.buy-notif.show{transform:translateX(0)}
.buy-notif img{width:46px;height:46px;border-radius:10px;object-fit:cover}
.buy-notif .bn-name{font-size:13px;font-weight:700;color:var(--dark)}
.buy-notif .bn-act{font-size:12px;color:var(--gray)}
.buy-notif .bn-time{font-size:11px;color:#22c55e;font-weight:600;margin-top:2px}
/* TRUST PRO (iconos SVG limpios) */
.trustpro{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;border-top:1px solid var(--border);padding-top:20px}
.tp-item{display:flex;flex-direction:column;align-items:center;text-align:center;gap:7px}
.tp-item svg{width:26px;height:26px;stroke:var(--teal);fill:none;stroke-width:1.8}
.tp-item .tp-t{font-size:11px;font-weight:700;color:var(--dark);line-height:1.25}
/* FAQ ACORDEON delante de la compra */
.qa-box{border:1px solid var(--border);border-radius:16px;overflow:hidden;margin-top:4px}
.qa-item{border-bottom:1px solid var(--border)}
.qa-item:last-child{border-bottom:none}
.qa-q{width:100%;background:#fff;border:none;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:10px;padding:15px 18px;font-size:14px;font-weight:700;color:var(--dark);text-align:left;transition:background .15s}
.qa-q:hover{background:var(--light)}
.qa-q .qa-ico{display:flex;align-items:center;gap:10px}
.qa-q .qa-ico svg{width:20px;height:20px;stroke:var(--teal);fill:none;stroke-width:1.8;flex-shrink:0}
.qa-arr{font-size:20px;color:var(--teal);transition:transform .25s;line-height:1}
.qa-item.open .qa-arr{transform:rotate(45deg)}
.qa-a{display:none;padding:0 18px 16px 48px;font-size:13px;color:var(--gray);line-height:1.6}
.qa-item.open .qa-a{display:block}
