})();
// STOCK baja lento
(function(){
  var el=document.getElementById('stockN');var n=38;
  setInterval(function(){ if(el&&n>9&&Math.random()>0.6){n--;el.textContent=n;} },22000);
})();

function initVideos(){
  var vids=document.querySelectorAll('.vid-phone');
  vids.forEach(function(phone){
    var vid=phone.querySelector('video');
    var ov=phone.querySelector('.vid-overlay');
    ov.addEventListener('click',function(){vid.play();ov.classList.add('hide')});
    vid.addEventListener('click',function(){if(vid.paused){vid.play();ov.classList.add('hide')}else{vid.pause();ov.classList.remove('hide')}});
  });
  var obs=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      var v=e.target.querySelector('video');
      var o=e.target.querySelector('.vid-overlay');
      if(e.isIntersecting){if(v)v.play();if(o)o.classList.add('hide')}
      else{if(v)v.pause();if(o)o.classList.remove('hide')}
    });
  },{threshold:0.6});
  vids.forEach(function(p){obs.observe(p)});
}
initVideos();
